# Example env file for scenario tests that need external credentials.
# Copy to .env.scenario.local (gitignored) and fill in real values.
# Source it before running scripts that need these:
#   set -a; source scripts/scenario-tests/.env.scenario.local; set +a

# --- Feishu Doubao 妙记 (voice transcription) for P0-2 meeting flow ---
# Apply at https://open.feishu.cn/  (Doubao 语音 / 妙记 product)
FEISHU_APP_ID=""           # numeric, ~10 digits
FEISHU_ACCESS_TOKEN=""     # rotates; treat as secret
FEISHU_SECRET_KEY=""       # long-lived; treat as secret

# --- Volcengine TOS (S3-compatible) for meeting audio + memory raw store ---
# Apply at https://console.volcengine.com/tos
# Storage backend selected per-workspace via:
#   PUT /api/workspaces/{id}/secrets/storage
#   { tos_access_key_id, tos_secret_access_key, tos_bucket,
#     tos_region, tos_endpoint }
TOS_ACCESS_KEY_ID=""        # AKLT...
TOS_SECRET_ACCESS_KEY=""    # base64
TOS_BUCKET=""               # bucket name
TOS_REGION="cn-beijing"     # default region
TOS_ENDPOINT="https://tos-s3-cn-beijing.volces.com"

# --- DashScope embedding for memory index (Phase 3) ---
# Apply at https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=""        # sk-...
DASHSCOPE_EMBED_MODEL="text-embedding-v4"   # 1024 dim

# --- E2E meeting test gate (Phase E) ---
# Run real-service e2e (uploads to TOS, calls Doubao 妙记 batch API):
#
#   set -a; source .env.scenario.local; set +a
#   export MEETING_E2E=1
#   export MEETING_E2E_AUDIO=/path/to/sample.mp3
#   cd server && DATABASE_URL=$DATABASE_URL \
#     go test ./internal/service -run TestMeetingService_E2E -v -timeout 10m
#
# Skips by default. Required env at run time:
#   TOS_*  FEISHU_*  MEETING_E2E_AUDIO  DATABASE_URL
MEETING_E2E="0"             # set to 1 to opt in
MEETING_E2E_AUDIO=""        # path to test mp3

# --- Backend dev server ---
BASE_URL="http://localhost:8080"

# --- Test user pool (master code 888888 works in non-prod) ---
TEST_EMAIL_PREFIX="scenario"
